---
import ClayCard from "@components/ClayCard.astro";
import SourceBadge from "@components/SourceBadge.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate, getMediaItems, uniqueSorted } from "@lib/content";

const media = await getMediaItems();
const sources = uniqueSorted(media.map((item) => item.data.source));
---

<BaseLayout title="Media | Khalil Nooh">
  <section class="section-heading">
    <div>
      <span class="eyebrow">Media</span>
      <h1>Mirrored public media</h1>
    </div>
    <p>Public media is mirrored for durability while retaining original links and attribution.</p>
  </section>

  <ClayCard tone="plain" class="filter-panel">
    <div class="filter-row">
      <button type="button" data-media-filter="all" aria-pressed="true">All</button>
      {sources.map((source) => <button type="button" data-media-source={source} aria-pressed="false">{source}</button>)}
    </div>
    <p class="filter-summary" data-media-count aria-live="polite">{media.length} media items shown</p>
  </ClayCard>

  <ClayCard tone="plain" class="empty-state" data-empty-state hidden>
    <h2>No matching media yet</h2>
    <p>Clear the source filter to bring the full media library back.</p>
  </ClayCard>

  <section class="grid two">
    {media.map((item, index) => (
      <ClayCard tone={index % 2 === 0 ? "orange" : "cyan"} class="media-tile media-item" data-source={item.data.source}>
        {item.data.localPath ? <img src={item.data.localPath} alt={item.data.title} /> : <div class="media-preview">{item.data.type}</div>}
        <div>
          <SourceBadge source={item.data.source} />
          <h2>{item.data.title}</h2>
          <p>{item.data.attribution}</p>
          <p><strong>{formatDate(item.data.capturedAt)}</strong></p>
          <a class="button" href={item.data.originalUrl}>Original media</a>
        </div>
      </ClayCard>
    ))}
  </section>

  <script>
    const mediaItems = [...document.querySelectorAll(".media-item")];
    const mediaCount = document.querySelector("[data-media-count]");
    const mediaEmptyState = document.querySelector("[data-empty-state]");
    const mediaAllButton = document.querySelector("[data-media-filter='all']");
    const mediaSourceButtons = [...document.querySelectorAll("[data-media-source]")];
    let activeSource = "";

    function applyMediaFilter() {
      let visibleCount = 0;
      mediaItems.forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        const isVisible = !activeSource || item.dataset.source === activeSource;
        item.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      if (mediaCount) mediaCount.textContent = `${visibleCount} ${visibleCount === 1 ? "media item" : "media items"} shown`;
      if (mediaEmptyState instanceof HTMLElement) mediaEmptyState.hidden = visibleCount !== 0;
      if (mediaAllButton instanceof HTMLElement) mediaAllButton.setAttribute("aria-pressed", activeSource ? "false" : "true");
      mediaSourceButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        button.setAttribute("aria-pressed", button.dataset.mediaSource === activeSource ? "true" : "false");
      });
    }

    mediaSourceButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        activeSource = activeSource === button.dataset.mediaSource ? "" : button.dataset.mediaSource || "";
        applyMediaFilter();
      });
    });
    mediaAllButton?.addEventListener("click", () => {
      activeSource = "";
      applyMediaFilter();
    });
    applyMediaFilter();
  </script>
</BaseLayout>
