---
import ClayCard from "@components/ClayCard.astro";
import SourceBadge from "@components/SourceBadge.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate, getMediaItems, getProjects, getPublishedPosts } from "@lib/content";

const posts = await getPublishedPosts();
const projects = await getProjects();
const media = await getMediaItems();
const tones = ["rose", "indigo", "cyan", "mint", "peach", "orange"] as const;
---

<BaseLayout title="Khalil Nooh | Profile, Portfolio, Timeline">
  <section class="hero">
    <ClayCard tone="plain" class="hero-card hero-card-primary">
      <span class="eyebrow">Public profile and proof archive</span>
      <h1>Khalil Nooh</h1>
      <p class="lead">
        A source-linked operating record for founder work, public thinking, media, and the evidence trail behind what gets built.
      </p>
      <div class="tag-row">
        <a class="button" href="/portfolio/">View portfolio</a>
        <a class="button primary" href="/timeline/">Explore timeline</a>
      </div>
    </ClayCard>

    <ClayCard tone="mint" class="hero-card proof-card">
      <span class="eyebrow">Start with the proof</span>
      <h2>Work, signals, and receipts in one place.</h2>
      <p>
        Posts from LinkedIn, Facebook, Audy's Vault, and future sources are organized into searchable entries with attribution, media, and review status.
      </p>
      <div class="proof-strip" aria-label="Site coverage">
        <span><strong>{projects.length}</strong> projects</span>
        <span><strong>{posts.length}</strong> posts</span>
        <span><strong>{media.length}</strong> media items</span>
      </div>
    </ClayCard>
  </section>

  <section>
    <div class="section-heading">
      <div>
        <span class="eyebrow">Featured work</span>
        <h2>Portfolio</h2>
      </div>
      <a class="button" href="/portfolio/">All projects</a>
    </div>
    <div class="grid">
      {projects.slice(0, 3).map((project, index) => (
        <ClayCard tone={tones[index % tones.length]} href={`/portfolio/#${project.id}`} class="feature-card">
          <h3>{project.data.title}</h3>
          <p>{project.data.description}</p>
          <div class="tag-row">{project.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
        </ClayCard>
      ))}
    </div>
  </section>

  <section>
    <div class="section-heading">
      <div>
        <span class="eyebrow">Latest public posts</span>
        <h2>Timeline</h2>
      </div>
      <a class="button" href="/timeline/">Open archive</a>
    </div>
    <div class="timeline-list">
      {posts.slice(0, 3).map((post, index) => (
        <ClayCard tone={tones[(index + 2) % tones.length]} href={`/timeline/${post.slug}/`} class="archive-card">
          <div class="timeline-card">
            <div>
              <p class="timeline-date">{formatDate(post.data.publishedAt)}</p>
              <SourceBadge source={post.data.source} status={post.data.crawlStatus} />
            </div>
            <div>
              <h3>{post.data.title}</h3>
              <p>{post.data.summary}</p>
              <div class="tag-row">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
            </div>
          </div>
        </ClayCard>
      ))}
    </div>
  </section>

  <section>
    <div class="section-heading">
      <div>
        <span class="eyebrow">Media</span>
        <h2>Mirrored highlights</h2>
      </div>
      <a class="button" href="/media/">Media library</a>
    </div>
    <div class="grid two">
      {media.slice(0, 2).map((item, index) => (
        <ClayCard tone={tones[(index + 4) % tones.length]} href="/media/" class="media-tile feature-card">
          {item.data.localPath ? <img src={item.data.localPath} alt={item.data.title} /> : <div class="media-preview">{item.data.type}</div>}
          <div>
            <h3>{item.data.title}</h3>
            <p>{item.data.attribution}</p>
          </div>
        </ClayCard>
      ))}
    </div>
  </section>
</BaseLayout>
