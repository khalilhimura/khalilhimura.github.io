{
  "name": "khalilnooh-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "test": "node --test tests/*.test.mjs",
    "build": "astro build && pagefind --site dist && node scripts/prepare-cloudflare-preview-config.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "deploy": "npm run build && wrangler deploy",
    "deploy:dry": "npm run build && wrangler deploy --dry-run",
    "crawl": "node scripts/crawl-public-sources.mjs",
    "crawl:dry": "node scripts/crawl-public-sources.mjs --dry-run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/rss": "^4.0.11",
    "@tailwindcss/vite": "^4.1.8",
    "astro": "^5.8.1",
    "pagefind": "^1.3.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  }
}
